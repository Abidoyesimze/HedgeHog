# Deployer private key (no 0x prefix needed for forge)
PRIVATE_KEY=0x...

# Operator wallet address (registered in vault and arbitrum contract)
OPERATOR_ADDRESS=0x...

# Set after running DeployArbitrum — paste HedgehogArbitrum address here
ARBITRUM_RECEIVER=0x...

# Set after running DeployUnichain — used by AVS operator
VAULT_ADDRESS=0x...
HOOK_ADDRESS=0x...
BRIDGE_ADDRESS=0x...

# RPC endpoints
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Block explorer API keys (optional — for contract verification)
ETHERSCAN_API_KEY=...
